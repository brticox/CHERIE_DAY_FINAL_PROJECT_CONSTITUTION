# CHERIE DAY — environment variables (docs/29_TECHNICAL_FOUNDATION_AND_QA_LOCK.md)
# Copy to .env.local and fill in. NEVER commit real secrets. Turkey-only commerce.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Payments: iyzico (primary) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- Payments: PayTR (secondary / fallback) ---
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_MAX_INSTALLMENT=0

# Configure this exact URL in the PayTR merchant panel:
# https://YOUR_DOMAIN/api/payments/paytr/callback

# --- Payments: webhook verification ---
PAYMENT_WEBHOOK_SECRET=

# --- Transactional notifications (disabled/captured locally by default) ---
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_FROM_NAME=CHERIE DAY
NOTIFICATION_REPLY_TO_EMAIL=
NOTIFICATION_WORKER_SECRET=
INTERNAL_CRON_SECRET=
NOTIFICATION_SEND_ENABLED=false
NOTIFICATION_STAFF_EMAILS=
# Development/preview only. Production rejects this setting when present.
NOTIFICATION_RECIPIENT_OVERRIDE=
APP_ENV=development

# --- Contact / handoff (public wa.me URL; not a secret) ---
NEXT_PUBLIC_WHATSAPP_CONTACT_URL=

# --- Consent ---
COOKIE_CONSENT_VERSION=1

# --- Optional feature flags (docs/46 §7) ---
SERVICE_DEPOSIT_ENABLED=false
SEARCH_PROVIDER=postgres
