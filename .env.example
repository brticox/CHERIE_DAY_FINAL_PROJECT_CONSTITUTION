# CHERIE DAY — environment variables (docs/29_TECHNICAL_FOUNDATION_AND_QA_LOCK.md)
# Copy to .env.local and fill in. NEVER commit real secrets. Turkey-only commerce.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Customer identity (providers stay disabled until external consoles are verified) ---
AUTH_GOOGLE_ENABLED=false
AUTH_APPLE_ENABLED=false
# Exact comma-separated origins only; never use wildcard preview origins.
AUTH_REDIRECT_ORIGINS=http://localhost:3000

# --- Payments: PayTR (the only implemented online checkout provider) ---
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_MAX_INSTALLMENT=0
# Set only when your own trusted reverse proxy overwrites forwarding headers.
# Vercel's x-vercel-forwarded-for is accepted without this flag.
TRUST_PROXY_HEADERS=false
# Local/CI simulator only; production readiness rejects this variable.
PAYTR_SIMULATOR_SECRET=
PAYTR_REFUND_ENABLED=false

# Configure this exact URL in the PayTR merchant panel:
# https://YOUR_DOMAIN/api/payments/paytr/callback

# --- Payments: webhook verification ---
PAYMENT_WEBHOOK_SECRET=

# --- Transactional notifications (disabled/captured locally by default) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_FROM_NAME=CHERIE DAY
NOTIFICATION_REPLY_TO_EMAIL=
EMAIL_HELLO=
EMAIL_SUPPORT=
EMAIL_ORDERS=
EMAIL_PAYMENTS=
EMAIL_LEGAL=
NOTIFICATION_WORKER_SECRET=
INTERNAL_CRON_SECRET=
CRON_SECRET=
PAYMENT_WORKER_SECRET=
NOTIFICATION_SEND_ENABLED=false
NOTIFICATION_STAFF_EMAILS=
# Required and fail-closed when APP_ENV=staging and sending is enabled.
NOTIFICATION_STAGING_RECIPIENT_ALLOWLIST=
# Development/preview/staging only. Production rejects this setting when present.
NOTIFICATION_RECIPIENT_OVERRIDE=
APP_ENV=development

# --- Contact / handoff (public wa.me URL; not a secret) ---
NEXT_PUBLIC_WHATSAPP_CONTACT_URL=

# --- Consent ---
COOKIE_CONSENT_VERSION=1

# --- Optional feature flags (docs/46 §7) ---
SERVICE_DEPOSIT_ENABLED=false
SEARCH_PROVIDER=postgres
