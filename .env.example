# CHERIE DAY — environment variables (docs/29_TECHNICAL_FOUNDATION_AND_QA_LOCK.md)
# Copy to .env.local and fill in. NEVER commit real secrets. Turkey-only commerce.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Payments: iyzico (primary) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- Payments: PayTR (secondary / fallback) ---
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# --- Payments: webhook verification ---
PAYMENT_WEBHOOK_SECRET=

# --- Email provider (Resend or chosen) ---
RESEND_API_KEY=

# --- Contact / handoff ---
WHATSAPP_CONTACT_URL=

# --- Consent ---
COOKIE_CONSENT_VERSION=1

# --- Optional feature flags (docs/46 §7) ---
SERVICE_DEPOSIT_ENABLED=false
SEARCH_PROVIDER=postgres
